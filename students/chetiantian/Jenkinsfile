pipeline {
  agent any
  stages {
    stage('Checkout from GitHub') {
      steps {
        echo 'GitHub repository: cwccty/web-cluster-course-design'
      }
    }
    stage('Build JSP WAR') {
      steps {
        dir('students/chetiantian/webapp') {
          sh 'mvn -q clean package -DskipTests'
        }
      }
    }
    stage('Deploy to Tomcat cluster') {
      steps {
        sh '''
          set -eux
          rm -rf /course-design-five/chetiantian/deploy/tomcat01/ROOT /course-design-five/chetiantian/deploy/tomcat01/ROOT.war
          rm -rf /course-design-five/chetiantian/deploy/tomcat02/ROOT /course-design-five/chetiantian/deploy/tomcat02/ROOT.war
          cp students/chetiantian/webapp/target/ROOT.war /course-design-five/chetiantian/deploy/tomcat01/ROOT.war
          cp students/chetiantian/webapp/target/ROOT.war /course-design-five/chetiantian/deploy/tomcat02/ROOT.war
          ls -l /course-design-five/chetiantian/deploy/tomcat01 /course-design-five/chetiantian/deploy/tomcat02
        '''
      }
    }
    stage('Verify') {
      steps {
        echo 'Student: 网络一班:车甜甜'
        echo 'Nginx: http://154.64.231.137:18280/session.jsp'
        echo 'Tomcat1: http://154.64.231.137:18291/session.jsp'
        echo 'Tomcat2: http://154.64.231.137:18292/session.jsp'
      }
    }
  }
}
